# Atlas CLI — API Keys (set at least one)
# Cost order: Cerebras (free) → Ollama (local) → NVIDIA (free) → OpenRouter (paid) → Anthropic (paid)

CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local, set URL if running)
# OLLAMA_URL=http://localhost:11434

# Telegram bot (required for src/telegram.ts)
TELEGRAM_BOT_TOKEN=

# Voice transcription (optional — bot works without it)
OPENAI_API_KEY=
